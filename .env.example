# Base URL for video assets hosted on Cloudflare R2.
# Leave UNSET in local dev to serve from /public/videos on disk.
# In production, set this to your r2.dev public URL (or custom domain),
# e.g. https://pub-XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX.r2.dev
#
# IMPORTANT: NEXT_PUBLIC_* env vars are inlined at BUILD time.
# Set this on Netlify/Vercel before triggering a build, or videos
# will 404 on the deployed site.
NEXT_PUBLIC_MEDIA_BASE_URL=
